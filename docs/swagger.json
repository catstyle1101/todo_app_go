                "parameters": [
                    {
                        "type": "integer",
                        "description": "Фильтрация статистики по конкретному пользователю",
                        "name": "user_id",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Начало промежутка рассмотрения статистики (включительно), формат `YYYY-MM-DD`",
                        "name": "from",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Конец промежутка рассмотрения статистики (не включительно), формат `YYYY-MM-DD`",
                        "name": "to",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Успешное получение статистики",
                        "schema": {
                            "$ref": "#/definitions/cmd_internal_features_statistics_transport_http.StatisticsResponse"
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "schema": {
                            "$ref": "#/definitions/github_com_catstyle1101_todo_app_go_cmd_internal_core_transport_http_response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/github_com_catstyle1101_todo_app_go_cmd_internal_core_transport_http_response.ErrorResponse"
                        }
                    }
                }
            }
        },
